BoxLayout:
    orientation: 'vertical'
    BoxLayout:
        orientation: 'horizontal'
        TextInput:
            id: input_number
            size_hint_x: 2
            text: '34'
            font_size: 48
        BoxLayout:
            orientation: 'vertical'
            Button:
                text: 'Up'
                # the following line specifies the function in the app class to call when the up button is pressed
                on_press: app.handle_up(input_number.text)
            Button:
                text: 'Down'
                # the following line specifies the function in the app class to call when the down button is pressed
                on_press: app.handle_down(input_number.text)
    Button:
        text: 'Convert m to km'
        # the following line specifies the function in the app class to call when the convert button is pressed
        on_press: app.handle_calculate(input_number.text)

    Label:
        id: output_label
        text: '54.717'
        font_size: 48
        color: (0, 0, 1, 1)
